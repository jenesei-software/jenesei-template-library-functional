{
  "author": "Cyril Strone",
  "name": "library-name",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/library-name.git"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "build"
  ],
  "keywords": [
    "functions",
  ],
  "exports": {
    "./function-test": {
      "import": "./build/function-test.es.js",
      "require": "./build/function-test.cjs.js",
      "types": "./build/function-test.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:main": "tsc && vite build",
    "biome:lint": "biome lint src",
    "biome:lint:check": "biome lint src --no-fix",
    "biome:format": "biome format --write src",
    "biome:format:check": "biome format src",
    "biome:migrate": "biome migrate --write",
    "biome:update": "biome update --write",
    "changelog": "conventional-changelog -p eslint -i CHANGELOG.md -s -r 0"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-bundle-analyzer": "^0.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^6.1.1"
  }
}