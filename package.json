{
  "author": "Cyril Strone",
  "name": "@jenesei-software/library-name",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jenesei-software/library-name.git"
  },
  "main": "./dist/library-name.umd.js",
  "module": "./dist/library-name.es.js",
  "types": "./dist/main.d.ts",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "ui",
    "styled-components"
  ],
  "exports": {
    ".": {
      "import": "./dist/library-name.es.js",
      "require": "./dist/library-name.umd.js",
      "types": "./dist/main.d.ts"
    }
  },
  "scripts": {
    "generate-icons": "node generate-icons.mjs",
    "build": "tsc && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/roboto": "^5.1.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.8.2",
    "@types/styled-components": "^5.1.34",
    "cross-env": "^7.0.3",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.0",
    "vite": "^5.4.10",
    "vite-plugin-bundle-analyzer": "^0.0.1",
    "vite-plugin-dts": "^4.3.0",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "peerDependencies": {
  },
  "dependencies": {}
}
