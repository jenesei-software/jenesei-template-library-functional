{
  "compilerOptions": {
    // Module setup for a Vite-built TypeScript library.
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,

    // This package runs in Node, not in the browser.
    "types": ["node"],
    "esModuleInterop": true,

    // Vite handles JS output, so `tsc` is only used for type-checking.
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    // Keep path aliases aligned with Vite config.
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@local/*": ["src/*"]
    },

    // Safety checks for published library code.
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["build", "node_modules"]
}
